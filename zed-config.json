// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "title_bar": {
    "show_branch_status_icon": true
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "show_edit_predictions": true,
  "autosave": "on_window_change",
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "default_profile": "write",
    "notify_when_agent_waiting": "never",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.6"
    }
  },
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light Soft",
    "dark": "Gruvbox Dark Soft"
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "Fira Code",
  "terminal": {
    "font_family": "MesloLGL Nerd Font Mono"
  },
  "languages": {
    "Helm": {
      "enable_language_server": true,
      "binary": {
        "path": "/opt/homebrew/bin/helm_ls",
        "arguments": ["serve"]
      }
    }
  },
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml"
    ]
  },
  "lsp": {
    "jdtls": {
      "settings": {
        "java_home": "/Users/djungermann/.jenv/versions/21",
        "lombok_support": true
      }
    }
  }
}
